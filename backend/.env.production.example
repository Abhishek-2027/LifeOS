# Production environment example - copy to .env and fill values
DATABASE_URL=postgresql+asyncpg://lifeos:lifeos_pass@localhost:5432/lifeos
SECRET_KEY=replace-with-a-secure-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
OLLAMA_URL=http://localhost:11434

# Optional production tuning
LOG_LEVEL=info

# If using PgVector, ensure pgvector is installed and configured on the DB
